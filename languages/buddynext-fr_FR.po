msgstr ""
"Trop de codes incorrects. Saisis à nouveau ton mot de passe pour redémarrer "
"la connexion."

#: includes/Auth/VerificationListener.php:203
#. translators: %s: site name
#, php-format
msgid "Verify your email address on %s"
msgstr "Vérifie ton adresse e-mail sur %s"

#: includes/Auth/VerificationListener.php:209
#. translators: 1: display name, 2: site name, 3: verification URL
