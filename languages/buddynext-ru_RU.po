msgstr ""
"Установите \"Authorization callback URL\" на URI перенаправления, "
"показанный ниже."

#: includes/Auth/SocialLogin.php:158
msgid "Click \"Register application\"."
msgstr "Нажмите \"Register application\"."

#: includes/Auth/SocialLogin.php:159
msgid ""
"Copy the \"Client ID\", then click \"Generate a new client secret\" and "
"copy that too."
msgstr ""
"Скопируйте \"Client ID\", затем нажмите \"Generate a new client secret\" и "
"скопируйте это также."

