#: blocks/bn-activity-feed/block.json
msgctxt "block description"
msgid ""
"Displays the community activity feed. Scope to home, profile, space, or "
"explore."
msgstr ""
"Exibe o feed de atividade da comunidade. Escopo para início, perfil, espaço "
"ou explorar."

#: blocks/bn-connection-button/block.json
msgctxt "block description"
msgid "Standalone connect/disconnect button for any user."
msgstr "Botão de conexão/desconexão independente para qualquer usuário."

#: blocks/bn-follow-button/block.json
msgctxt "block description"
msgid "Standalone follow/unfollow button for any user."
msgstr "Botão de seguir/deixar de seguir independente para qualquer usuário."

#: blocks/bn-header-user-menu/block.json
msgctxt "block description"
msgid ""
"Logged-in header section: notification bell, messages icon, and avatar with "
"a profile dropdown + log out. Works as a block-based widget in any theme's "
"header."
msgstr ""
"Seção de cabeçalho conectada: sino de notificação, ícone de mensagens e "
"avatar com menu suspenso de perfil + sair. Funciona como um widget baseado "
"em bloco no cabeçalho de qualquer tema."

#: blocks/bn-member-card/block.json
msgctxt "block description"
msgid ""
"Single user card with avatar, name, and follow button. Ideal for widgets "
"and sidebars."
msgstr ""
"Cartão de usuário único com avatar, nome e botão de seguir. Ideal para "
"widgets e barras laterais."

#: blocks/bn-member-directory/block.json
msgctxt "block description"
msgid "Full filterable member grid or list with search and filters."
msgstr "Grade ou lista de membro totalmente filtrável com pesquisa e filtros."

#: blocks/bn-my-spaces/block.json
msgctxt "block description"
msgid "Lists the spaces the current user is a member of."
msgstr "Lista os espaços dos quais o usuário atual é membro."

#: blocks/bn-notification-bell/block.json
msgctxt "block description"
msgid "Bell icon with unread notification count for custom header areas."
msgstr ""
"Ícone de sino com contagem de notificações não lidas para áreas de "
"cabeçalho personalizadas."

#: blocks/bn-post-composer/block.json
msgctxt "block description"
msgid "Post creation box — what's on your mind."
msgstr "Caixa de criação de postagem — o que você pensa."

#: blocks/bn-profile-completion-bar/block.json
msgctxt "block description"
msgid "Profile completion progress bar with prompt cards for incomplete sections."
msgstr ""
"Barra de progresso de conclusão do perfil com cartões de prompt para seções "
"incompletas."

#: blocks/bn-profile-fields/block.json
msgctxt "block description"
msgid ""
"Renders a profile field group such as basic info, work experience, or "
"education."
msgstr ""
"Renderiza um grupo de campo de perfil, como informações básicas, "
"experiência profissional ou educação."

#: blocks/bn-profile-header/block.json
msgctxt "block description"
msgid ""
"User profile header with avatar, cover photo, name, bio, social links, and "
"follow/connect buttons."
msgstr ""
"Cabeçalho de perfil do usuário com avatar, foto de capa, nome, biografia, "
"links sociais e botões de seguir/conectar."

#: blocks/bn-search-bar/block.json
msgctxt "block description"
msgid "Unified BuddyNext search input that opens grouped results."
msgstr "Entrada de pesquisa BuddyNext unificada que abre resultados agrupados."

#: blocks/bn-space-card/block.json
msgctxt "block description"
msgid "Single space card for featured space callouts."
msgstr "Cartão de espaço único para callouts de espaço em destaque."

#: blocks/bn-space-directory/block.json
msgctxt "block description"
msgid "Filterable grid of community spaces, filterable by category and membership."
msgstr ""
"Grade filtrável de espaços da comunidade, filtrável por categoria e "
"filiação."

#: blocks/bn-trending-hashtags/block.json
msgctxt "block description"
msgid "Displays trending hashtags as a list or tag cloud."
msgstr "Exibe hashtags em tendência como uma lista ou nuvem de tags."

