msgstr "Inviami un codice via email invece"

#: includes/Auth/TwoFactorService.php:146
msgid "Start the setup again — the previous attempt expired."
msgstr "Avvia di nuovo la configurazione — il tentativo precedente è scaduto."

#: includes/Auth/TwoFactorService.php:149
msgid "That code did not match. Check your authenticator app and try again."
msgstr ""
"Quel codice non corrispondeva. Controlla la tua app di autenticazione e "
"riprova."

#: includes/Auth/TwoFactorService.php:259
#. translators: %s: site name.
#, php-format
msgid "Your %s sign-in code"
msgstr "Il tuo codice di accesso %s"

#: includes/Auth/TwoFactorService.php:264
#. translators: 1: 6-digit code, 2: minutes until expiry.
#, php-format
msgid ""
"Your verification code is: %1$s\n"
"\n"
"It expires in %2$d minutes. If you did not try to sign in, you can ignore "
"this email."
msgstr ""
"Il tuo codice di verifica è: %1$s\n"
"\n"
"Scade tra %2$d minuti. Se non hai provato ad accedere, puoi ignorare questa "
"email."

#: includes/Auth/TwoFactorService.php:405
msgid ""
"Too many incorrect codes. Please enter your password again to restart "
"sign-in."
msgstr ""
"Troppi codici non corretti. Immetti di nuovo la tua password per riavviare "
"l'accesso."

