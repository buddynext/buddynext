msgid "Export / Import settings"
msgstr "Esporta / Importa impostazioni"

#: includes/Admin/ToolsTab.php:236
msgid ""
"Download all BuddyNext settings as a JSON file, or restore them from a "
"previous export. Only BuddyNext option keys are touched."
msgstr ""
