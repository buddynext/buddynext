# Composer vendor/ is dev/build tooling only (phpcs, phpstan, phpunit) and is
# never shipped. Runtime never touches it: the plugin uses a hand-written PSR-4
# autoloader and bundles its runtime deps (Action Scheduler, EDD SL SDK) under libs/.
/vendor/

# PHPUnit
.phpunit.result.cache
.phpunit.cache/

# macOS
.DS_Store
**/.DS_Store

# IDE
.idea/
.vscode/
*.swp

# Build output
/dist/
/build/

# Local config
.env
wp-tests-config.php

# Brainstorm scratch (legacy mockups regenerated locally, do not track)
/.superpowers/

# Node / Playwright
node_modules/
tests/e2e/_report/
tests/e2e/_results/
playwright/.cache/

# Ad-hoc verification screenshots written into the repo dir by Playwright MCP
# (the server CWD is the symlinked plugin dir). Never commit these.
/a-*.png
/aud-*.png
/mig-*.png
/ux-*.png
/walk-*.png
/mod-reports*.png
/cover-test*.png
/*.playwright-mcp/
/s-*.png
/r-*.png
/icons*.png
/*-screenshot*.png
audit/cert-ledger.json
.cert.json

# flow-audit rebuildable graph cache (regenerated by wppqa flow-audit)
audit/flow.json

# Local test runner output
test-results/

# Internal dev docs + audit live in the private buddynext-pro repo (free-internal/).
# Public repo keeps customer-facing docs (docs/website/) only. audit/ stays on disk
# (gitignored) so local tooling resolves the regenerated manifest + flow-audit baseline.
/audit/
/docs/*
!/docs/website/
