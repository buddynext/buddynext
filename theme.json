{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "primary",
          "color": "#0073aa",
          "name": "BuddyNext Primary"
        },
        {
          "slug": "primary-hover",
          "color": "#005f8e",
          "name": "BuddyNext Primary Hover"
        },
        {
          "slug": "primary-light",
          "color": "#e8f4fb",
          "name": "BuddyNext Primary Light"
        },
        {
          "slug": "base",
          "color": "#ffffff",
          "name": "BuddyNext Background"
        },
        {
          "slug": "base-subtle",
          "color": "#f8f8f7",
          "name": "BuddyNext Background Subtle"
        },
        {
          "slug": "base-hover",
          "color": "#f1f1f0",
          "name": "BuddyNext Background Hover"
        },
        {
          "slug": "foreground",
          "color": "#37352f",
          "name": "BuddyNext Text Primary"
        },
        {
          "slug": "foreground-secondary",
          "color": "#787774",
          "name": "BuddyNext Text Secondary"
        },
        {
          "slug": "foreground-tertiary",
          "color": "#aeaca8",
          "name": "BuddyNext Text Tertiary"
        },
        {
          "slug": "border",
          "color": "#e8e8e5",
          "name": "BuddyNext Border"
        },
        {
          "slug": "success",
          "color": "#059669",
          "name": "BuddyNext Green"
        },
        {
          "slug": "warning",
          "color": "#d97706",
          "name": "BuddyNext Amber"
        },
        {
          "slug": "error",
          "color": "#dc2626",
          "name": "BuddyNext Red"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "body",
          "name": "BuddyNext Body",
          "fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, sans-serif"
        },
        {
          "slug": "display",
          "name": "BuddyNext Display",
          "fontFamily": "'Plus Jakarta Sans', 'Inter', sans-serif"
        }
      ],
      "fontSizes": [
        { "slug": "2xs",    "size": "9px",  "name": "BuddyNext 2XS" },
        { "slug": "xs",     "size": "11px", "name": "BuddyNext XS" },
        { "slug": "sm",     "size": "13px", "name": "BuddyNext SM" },
        { "slug": "md",     "size": "14px", "name": "BuddyNext MD" },
        { "slug": "medium", "size": "16px", "name": "BuddyNext Base (16px)" },
        { "slug": "large",  "size": "18px", "name": "BuddyNext LG (18px)" },
        { "slug": "xl",     "size": "20px", "name": "BuddyNext XL" },
        { "slug": "2xl",    "size": "24px", "name": "BuddyNext 2XL" },
        { "slug": "3xl",    "size": "30px", "name": "BuddyNext 3XL" },
        { "slug": "4xl",    "size": "38px", "name": "BuddyNext 4XL" },
        { "slug": "5xl",    "size": "48px", "name": "BuddyNext 5XL" }
      ],
      "fontWeights": [
        { "slug": "normal",    "weight": "400", "name": "Normal" },
        { "slug": "medium",    "weight": "500", "name": "Medium" },
        { "slug": "semibold",  "weight": "600", "name": "Semibold" },
        { "slug": "bold",      "weight": "700", "name": "Bold" },
        { "slug": "extrabold", "weight": "800", "name": "Extra Bold" },
        { "slug": "black",     "weight": "900", "name": "Black" }
      ]
    },
    "spacing": {
      "spacingSizes": [
        { "slug": "10",  "size": "4px",  "name": "BuddyNext Space 1" },
        { "slug": "20",  "size": "8px",  "name": "BuddyNext Space 2" },
        { "slug": "30",  "size": "12px", "name": "BuddyNext Space 3" },
        { "slug": "40",  "size": "16px", "name": "BuddyNext Space 4" },
        { "slug": "50",  "size": "20px", "name": "BuddyNext Space 5" },
        { "slug": "60",  "size": "24px", "name": "BuddyNext Space 6" },
        { "slug": "80",  "size": "32px", "name": "BuddyNext Space 8" },
        { "slug": "100", "size": "40px", "name": "BuddyNext Space 10" },
        { "slug": "120", "size": "48px", "name": "BuddyNext Space 12" },
        { "slug": "140", "size": "56px", "name": "BuddyNext Space 14" },
        { "slug": "160", "size": "64px", "name": "BuddyNext Space 16" }
      ]
    },
    "custom": {
      "buddynext": {
        "radius": {
          "sm":   "4px",
          "md":   "8px",
          "lg":   "12px",
          "xl":   "16px",
          "full": "9999px"
        }
      }
    }
  }
}
