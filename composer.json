{
  "name": "wbcom-designs/buddynext",
  "description": "BuddyNext — Social layer for WordPress",
  "type": "wordpress-plugin",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "yoast/phpunit-polyfills": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "BuddyNext\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BuddyNext\\Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true
  }
}
