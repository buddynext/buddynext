parameters:
    ignoreErrors:
        # MediaClient guards every WPMediaVerse call with class_exists() +
        # method_exists() and resolves \WPMediaVerse\Core\Plugin::container()
        # only when present. WPMediaVerse is an external plugin (not a Composer
        # dependency), so PHPStan cannot see the class and reads the runtime
        # guard as impossible / the static call as an unknown class. Correct at
        # runtime; the guard is intentional.
        -
            message: '#method_exists\(\) with .+ and ''container'' will always evaluate to false\.$#'
            path: includes/Media/MediaClient.php
            count: 1
        -
            message: "#^Call to static method container\\(\\) on an unknown class WPMediaVerse\\\\Core\\\\Plugin\\.$#"
            path: includes/Media/MediaClient.php
            count: 1

        # Defensive guard: $prefixes comes from the buddynext_allowed_assets
        # filter, which a third-party callback could populate with non-string
        # entries. PHPStan infers string[] from the default, so it reads the
        # is_string() guard as always-true — but the guard protects against
        # filter misuse and must stay.
        -
            message: "#^Call to function is_string\\(\\) with string will always evaluate to true\\.$#"
            path: includes/Core/AssetIsolation.php
            count: 1

        # nav_menu_selected_id() is a WordPress admin function used
        # inside the nav-menus admin screen. It is declared in
        # wp-admin/includes/nav-menu.php which is loaded late in the admin
        # bootstrap. The WordPress stubs shipped with phpstan-wordpress do not
        # declare this function, producing a false-positive here.
        -
            message: "#^Function nav_menu_selected_id not found\\.$#"
            path: includes/Core/Plugin.php
            count: 1
