{
  "name": "buddynext-e2e",
  "version": "1.0.3",
  "private": true,
  "description": "Playwright end-to-end test suite for BuddyNext Free + Pro. The PHP plugin lives alongside; this file exists only to host the e2e tooling.",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --project=desktop",
    "test:e2e:ipad": "playwright test --project=ipad",
    "test:e2e:mobile": "playwright test --project=mobile",
    "test:e2e:report": "playwright show-report tests/e2e/_report",
    "test:e2e:install": "playwright install chromium webkit"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3"
  }
}