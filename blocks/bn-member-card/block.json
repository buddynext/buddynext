{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "buddynext/member-card",
	"title": "Member Card",
	"category": "buddynext",
	"description": "Single user card with avatar, name, and follow button. Ideal for widgets and sidebars.",
	"keywords": [ "buddynext", "member", "card", "user", "widget" ],
	"textdomain": "buddynext",
	"editorScript": "buddynext-blocks-editor",
	"style": "file:../../assets/css/blocks.css",
	"supports": {
		"color": { "background": true, "text": true },
		"typography": { "fontSize": true },
		"spacing": { "padding": true, "margin": true }
	},
	"attributes": {
		"userId": {
			"type": "integer",
			"default": 0
		}
	},
	"example": {}
}
