{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "buddynext/search-bar",
	"title": "Search Bar",
	"category": "buddynext",
	"description": "Unified BuddyNext search input that opens grouped results.",
	"keywords": [ "buddynext", "search", "bar", "unified" ],
	"textdomain": "buddynext",
	"editorScript": "buddynext-blocks-editor",
	"style": "file:../../assets/css/blocks.css",
	"supports": {
		"color": { "background": true, "text": true },
		"typography": { "fontSize": true },
		"spacing": { "padding": true, "margin": true }
	},
	"attributes": {
		"placeholder": {
			"type": "string",
			"default": ""
		}
	},
	"example": {}
}
