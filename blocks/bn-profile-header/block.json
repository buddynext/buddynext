{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "buddynext/profile-header",
	"title": "Profile Header",
	"category": "buddynext",
	"description": "User profile header with avatar, cover photo, name, bio, social links, and follow/connect buttons.",
	"keywords": [ "buddynext", "profile", "header", "user" ],
	"textdomain": "buddynext",
	"editorScript": "buddynext-blocks-editor",
	"style": "file:../../assets/css/blocks.css",
	"supports": {
		"color": { "background": true, "text": true },
		"typography": { "fontSize": true },
		"spacing": { "padding": true, "margin": true }
	},
	"attributes": {
		"userId": {
			"type": "integer",
			"default": 0
		},
		"showStats": {
			"type": "boolean",
			"default": true
		},
		"showActions": {
			"type": "boolean",
			"default": true
		}
	},
	"example": {}
}
