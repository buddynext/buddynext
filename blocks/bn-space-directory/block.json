{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "buddynext/space-directory",
	"title": "Space Directory",
	"category": "buddynext",
	"description": "Filterable grid of community spaces, filterable by category and membership.",
	"keywords": [ "buddynext", "spaces", "directory", "community" ],
	"textdomain": "buddynext",
	"editorScript": "file:../../assets/js/blocks.js",
	"style": "file:../../assets/css/blocks.css",
	"supports": {
		"color": { "background": true, "text": true },
		"typography": { "fontSize": true },
		"spacing": { "padding": true, "margin": true }
	},
	"attributes": {
		"perPage": {
			"type": "integer",
			"default": 12
		},
		"layout": {
			"type": "string",
			"default": "grid",
			"enum": [ "grid", "list" ]
		}
	},
	"example": {}
}
