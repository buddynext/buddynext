{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "buddynext/space-card",
	"title": "Space Card",
	"icon": "id-alt",
	"category": "buddynext",
	"description": "Single space card for featured space callouts.",
	"keywords": [ "buddynext", "space", "card", "featured" ],
	"textdomain": "buddynext",
	"editorScript": "buddynext-blocks-editor",
	"viewScriptModule": "@buddynext/spaces",
	"style": "file:../../assets/css/blocks.css",
	"supports": {
		"color": { "background": true, "text": true },
		"typography": { "fontSize": true },
		"spacing": { "padding": true, "margin": true }
	},
	"attributes": {
		"spaceId": {
			"type": "integer",
			"default": 0
		}
	},
	"example": {}
}
