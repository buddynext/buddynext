{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "buddynext/trending-hashtags",
	"title": "Trending Hashtags",
	"category": "buddynext",
	"description": "Displays trending hashtags as a list or tag cloud.",
	"keywords": [ "buddynext", "hashtags", "trending", "topics" ],
	"textdomain": "buddynext",
	"editorScript": "buddynext-blocks-editor",
	"style": "file:../../assets/css/blocks.css",
	"supports": {
		"color": { "background": true, "text": true },
		"typography": { "fontSize": true },
		"spacing": { "padding": true, "margin": true }
	},
	"attributes": {
		"count": {
			"type": "integer",
			"default": 10
		},
		"display": {
			"type": "string",
			"default": "list",
			"enum": [ "list", "cloud" ]
		}
	},
	"example": {}
}
