{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "buddynext/profile-fields",
	"title": "Profile Fields",
	"category": "buddynext",
	"description": "Renders a profile field group such as basic info, work experience, or education.",
	"keywords": [ "buddynext", "profile", "fields", "info" ],
	"textdomain": "buddynext",
	"editorScript": "file:../../assets/js/blocks.js",
	"style": "file:../../assets/css/blocks.css",
	"supports": {
		"color": { "background": true, "text": true },
		"typography": { "fontSize": true },
		"spacing": { "padding": true, "margin": true }
	},
	"attributes": {
		"userId": {
			"type": "integer",
			"default": 0
		},
		"group": {
			"type": "string",
			"default": ""
		}
	},
	"example": {}
}
