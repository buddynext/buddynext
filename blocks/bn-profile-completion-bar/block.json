{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "buddynext/profile-completion-bar",
	"title": "Profile Completion Bar",
	"category": "buddynext",
	"description": "Profile completion progress bar with prompt cards for incomplete sections.",
	"keywords": [ "buddynext", "profile", "completion", "progress" ],
	"textdomain": "buddynext",
	"editorScript": "buddynext-blocks-editor",
	"style": "file:../../assets/css/blocks.css",
	"supports": {
		"color": { "background": true, "text": true },
		"typography": { "fontSize": true },
		"spacing": { "padding": true, "margin": true }
	},
	"attributes": {
		"userId": {
			"type": "integer",
			"default": 0
		}
	},
	"example": {}
}
