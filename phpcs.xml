<?xml version="1.0"?>
<ruleset name="BuddyNext">
	<description>BuddyNext coding standards — WordPress standard with PSR-4 filename exclusions.</description>

	<!-- Scan these paths -->
	<file>includes/</file>
	<file>templates/</file>
	<file>tests/</file>

	<!-- Exclude generated/third-party paths -->
	<exclude-pattern>vendor/</exclude-pattern>
	<exclude-pattern>node_modules/</exclude-pattern>
	<!-- Vendored runtime deps (Action Scheduler, EDD SL SDK) ship verbatim from
	     upstream and are not authored to this ruleset — a dep refresh must not
	     trip the gate, which passes staged paths explicitly. -->
	<exclude-pattern>libs/</exclude-pattern>

	<!-- Base standard -->
	<rule ref="WordPress">
		<!--
		  The project uses Composer PSR-4 autoloading which requires PascalCase filenames
		  (e.g. CommentService.php). WordPress expects class-comment-service.php.
		  PSR-4 takes precedence — suppress the entire file-naming sniff to avoid
		  false positives on every PascalCase file in the codebase.
		-->
		<exclude name="WordPress.Files.FileName"/>

		<!--
		  BuddyNext manages 28 custom bn_* tables with no WP_Query equivalents.
		  Direct $wpdb queries against these tables are intentional and correct;
		  caching is handled per-service via wp_cache_get/set where appropriate.
		  Disabling these sniffs avoids false positives across every service class.
		-->
		<exclude name="WordPress.DB.DirectDatabaseQuery.DirectQuery"/>
		<exclude name="WordPress.DB.DirectDatabaseQuery.NoCaching"/>
	</rule>

	<!-- PHP minimum version -->
	<config name="minimum_supported_wp_version" value="6.9"/>
	<config name="testVersion" value="8.1-"/>
</ruleset>
